platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  
  # We are skipping the automatic flutter_install because the helper script is missing.
  # This lets 'pod install' finish so the build can start.
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
