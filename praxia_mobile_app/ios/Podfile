platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # We bypass the automatic flutter_install call since the helper script is missing.
  # Codemagic will still compile the main app code.
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      # This ensures your 'health' plugin requirement (iOS 14) is met
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end