# 1. Define the path to the Flutter SDK scripts relative to this file
flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

# This is the "Magic" line that links the Flutter helper script
load File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'flutter', 'ios', 'scripts', 'pod_helper.rb') rescue load File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')

platform :ios, '14.0'

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # 2. Call the helper function now that it's loaded
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Force iOS 14.0 for the health plugin
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end